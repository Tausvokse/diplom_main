# Connect to Supabase via connection pooling
DATABASE_URL=postgresql://...

# Direct connection to the database. Used for migrations
DIRECT_URL=postgresql://...

# JWT configuration
JWT_SECRET=your-secure-secret
JWT_REFRESH_SECRET=your-secure-refresh-secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Diia webhook (optional for basic functionality)
DIIA_WEBHOOK_SECRET=your-webhook-secret

# Port Configuration (Heroku sets PORT automatically)
PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# For production (Heroku):
# NODE_ENV=production
# CORS_ORIGINS=https://your-app.herokuapp.com
# FRONTEND_URL=https://your-app.herokuapp.com
